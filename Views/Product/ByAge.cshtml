@model List<buytoy.Models.ProductModel>

@{
    ViewData["Title"] = ViewData["Title"] ?? "Sản phẩm theo độ tuổi";
}

<div class="container py-4">
    <h4 class="mb-4 text-center text-success fw-bold">@ViewData["Title"]</h4>

    <div class="row">
        @if (Model != null && Model.Any())
        {
            foreach (var product in Model)
            {
                <div class="col-md-3 mb-4">
                    <div class="card h-100 shadow-sm">
                        <img src="@Url.Content("~/media/products/" + product.Image)" class="card-img-top" alt="@product.Name" />
                        <div class="card-body">
                            <h5 class="card-title">@product.Name</h5>
                            <p class="card-text text-muted">@product.Price.ToString("N0") VNĐ</p>
                        </div>
                        <div class="card-footer text-center">
                            <a href="@Url.Action("Details", "Product", new { id = product.Id })" class="btn btn-sm btn-success">Xem chi tiết</a>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <p class="text-center">Không có sản phẩm phù hợp.</p>
        }
    </div>
</div>
