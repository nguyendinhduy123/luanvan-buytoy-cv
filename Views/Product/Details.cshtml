@model buytoy.Models.ViewModels.ProductDetailsViewModel

@{
    ViewData["Title"] = Model.ProductDetails.Name;
}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

<div class="row">
    <!-- Sidebar -->
    <div class="col-lg-3 mb-4">
        @Html.Partial("_SidebarPartial")
    </div>

    <!-- Product Details -->
    <div class="col-lg-9">
        <div class="card shadow rounded-4 p-4 mb-4">
            <div class="row g-4">
                <!-- Product Image -->
                <div class="col-md-5 text-center">
                    <img src="~/media/products/@Model.ProductDetails.Image" alt="@Model.ProductDetails.Name"
                         class="img-fluid rounded" style="max-height: 350px; object-fit: contain;" />
                    <div class="mt-3">
                        <h6 class="text-muted">Zoom chi tiết</h6>
                    </div>
                </div>

                <!-- Product Info -->
                <div class="col-md-7">
                    <h2 class="fw-bold">@Model.ProductDetails.Name</h2>
                    @if (Model.TotalRatings > 0)
                    {
                        <div class="mb-2">
                            <span class="text-warning">
                                @{
                                    double avg = Model.StarAverage;
                                    for (int i = 1; i <= 5; i++)
                                    {
                                        if (i <= avg)
                                        {
                                            <i class="fas fa-star"></i>
                                        }
                                        else if (i - avg < 1)
                                        {
                                            <i class="fas fa-star-half-alt"></i>
                                        }
                                        else
                                        {
                                            <i class="far fa-star"></i>
                                        }
                                    }
                                }
                            </span>
                            <span class="text-muted ms-2">
                                (@Model.TotalRatings đánh giá - Trung bình @Model.StarAverage ⭐️)
                            </span>
                        </div>
                    }

                    <p class="text-muted fst-italic lead">@Model.ProductDetails.ShortDescription</p>

                    <div class="mb-3">
                        <span class="fs-5 fw-bold text-danger">@Model.ProductDetails.Price.ToString("N0") ₫</span>
                        @if (Model.ProductDetails.Quantity > 0)
                        {
                            <span class="badge bg-success ms-2">Còn hàng</span>
                        }
                        else
                        {
                            <span class="badge bg-danger ms-2">Hết hàng</span>
                        }
                    </div>

                    <ul class="list-unstyled mb-3">
                        <li><strong>Thương hiệu:</strong> @Model.ProductDetails.Brand?.Name</li>
                        <li><strong>Danh mục:</strong> @Model.ProductDetails.Category?.Name</li>
                        <li><strong>Tình trạng:</strong> Mới 100%</li>
                    </ul>
                    @if (Model.ProductDetails.MaxAge <= 12)
                    {
                        <span class="badge bg-info">👶 Dành cho Trẻ em</span>
                    }
                    else if (Model.ProductDetails.MinAge > 12)
                    {
                        <span class="badge bg-warning">🧑 Dành cho Người lớn</span>
                    }

                    @if (Model.ProductDetails.Quantity > 0)
                    {
                        <form asp-action="Add" asp-controller="Cart" method="get">
                            <div class="input-group mb-3" style="max-width: 140px;">
                                <input type="number" name="quantity" value="1" min="1" class="form-control" />
                                <input type="hidden" name="Id" value="@Model.ProductDetails.Id" />
                            </div>
                            <button type="submit" class="btn btn-warning btn-lg rounded-pill px-4">
                                <i class="fas fa-cart-plus me-2"></i>Thêm vào giỏ
                            </button>
                        </form>
                    }
                    else
                    {
                        <div class="text-danger fw-semibold fs-5">Sản phẩm này hiện đang hết hàng.</div>
                    }
                    <p>@Model.ProductDetails.Quantity</p>
                    <div class="mt-4">
                        <p>
                            Chia sẻ:
                            <a href="https://www.facebook.com/profile.php?id=61577834414087" target="_blank">
                                <i class="fab fa-facebook fa-lg me-2"></i>
                            </a>
                            <a href="#"><i class="fab fa-twitter fa-lg me-2"></i></a>
                            <a href="#"><i class="fab fa-pinterest fa-lg"></i></a>
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tabs: Mô tả & Đánh giá -->
        <div class="card shadow rounded-4 p-4">
            <ul class="nav nav-tabs mb-3" id="productTab" role="tablist">
                <li class="nav-item">
                    <a class="nav-link active" data-bs-toggle="tab" href="#description">Mô tả chi tiết</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" data-bs-toggle="tab" href="#reviews">Đánh giá</a>
                </li>
            </ul>

            <div class="tab-content">
                <!-- Mô tả chi tiết -->
                <div class="tab-pane fade show active" id="description">
                    <div class="pt-2">@Html.Raw(Model.ProductDetails.Description)</div>
                </div>

                <!-- Đánh giá -->
                <div class="tab-pane fade" id="reviews">
                    <div class="pt-2">
                        @if (Model.Ratings != null && Model.Ratings.Any())
                        {
                            foreach (var review in Model.Ratings)
                            {
                                <div class="mb-3 border-bottom pb-2">
                                    <strong>@review.Name</strong> - <small class="text-muted">@review.Email</small>
                                    <div>⭐️ Đánh giá: @review.Star</div>
                                    <p>@review.Comment</p>
                                </div>
                            }
                        }
                        else
                        {
                            <p class="fst-italic">Chưa có đánh giá nào. Hãy là người đầu tiên nhận xét!</p>
                        }

                        <!-- Form đánh giá -->
                        <form asp-action="CommentProduct" method="post">
                            <input asp-for="ProductId" type="hidden" value="@Model.ProductDetails.Id" />
                            <div class="row g-3 mt-3">
                                <div class="col-md-6">
                                    <input asp-for="Name" class="form-control" placeholder="Họ tên" />
                                    <span asp-validation-for="Name" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6">
                                    <input asp-for="Email" class="form-control" placeholder="Email" />
                                    <span asp-validation-for="Email" class="text-danger small"></span>
                                </div>
                                <div class="col-12">
                                    <textarea asp-for="Comment" class="form-control" rows="3"
                                              placeholder="Nội dung đánh giá..."></textarea>
                                    <span asp-validation-for="Comment" class="text-danger small"></span>
                                </div>
                                <div class="col-md-4">
                                    <select asp-for="Star" class="form-select">
                                        <option value="5">⭐️⭐️⭐️⭐️⭐️ (5)</option>
                                        <option value="4">⭐️⭐️⭐️⭐️ (4)</option>
                                        <option value="3">⭐️⭐️⭐️ (3)</option>
                                        <option value="2">⭐️⭐️ (2)</option>
                                        <option value="1">⭐️ (1)</option>
                                    </select>
                                </div>
                                <div class="col-12 text-end">
                                    <button type="submit" class="btn btn-primary">Gửi đánh giá</button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sản phẩm liên quan -->
        <div class="card shadow rounded-4 p-4 mt-5">
            <h4 class="mb-4">Sản phẩm liên quan</h4>
            @if (ViewBag.Related != null && ((List<buytoy.Models.ProductModel>)ViewBag.Related).Any())
            {
                var relatedProducts = (List<buytoy.Models.ProductModel>)ViewBag.Related;
                <div class="row">
                    @foreach (var related in relatedProducts)
                    {
                        <div class="col-md-3 col-sm-6 mb-4">
                            <div class="productinfo text-center border shadow-sm rounded p-2 h-100">
                                <a asp-action="Details" asp-controller="Product" asp-route-id="@related.Id">
                                    <img src="~/media/products/@related.Image" alt="@related.Name"
                                         class="img-fluid mb-2" style="height: 150px; object-fit: contain;" />
                                    <h6 class="fw-bold text-truncate">@related.Name</h6>
                                    <p class="text-danger mb-1">@related.Price.ToString("N0") ₫</p>
                                    <p class="mb-0 text-muted"><small>Danh mục: @related.Category?.Name</small></p>
                                    <p class="mb-0 text-muted"><small>Thương hiệu: @related.Brand?.Name</small></p>
                                </a>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="text-muted">Không có sản phẩm liên quan.</p>
            }
        </div>
    </div>
</div>
<!-- Sản phẩm đã xem gần đây -->
<div class="card shadow rounded-4 p-4 mt-5">
    <h4 class="mb-4">Bạn đã xem gần đây</h4>
    @if (ViewBag.RecentlyViewed != null && ((List<buytoy.Models.ProductModel>)ViewBag.RecentlyViewed).Any())
    {
        var viewed = (List<buytoy.Models.ProductModel>)ViewBag.RecentlyViewed;
        <div class="row">
            @foreach (var item in viewed)
            {
                <div class="col-md-3 col-sm-6 mb-4">
                    <div class="productinfo text-center border shadow-sm rounded p-2 h-100">
                        <a asp-action="Details" asp-controller="Product" asp-route-id="@item.Id">
                            <img src="~/media/products/@item.Image" alt="@item.Name"
                                 class="img-fluid mb-2" style="height: 150px; object-fit: contain;" />
                            <h6 class="fw-bold text-truncate">@item.Name</h6>
                            <p class="text-danger mb-1">@item.Price.ToString("N0") ₫</p>
                            <p class="mb-0 text-muted"><small>Danh mục: @item.Category?.Name</small></p>
                            <p class="mb-0 text-muted"><small>Thương hiệu: @item.Brand?.Name</small></p>

                        </a>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <p class="text-muted">Chưa có sản phẩm nào được xem gần đây.</p>
    }
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    @if (TempData["success"] != null)
    {
        <script>
            Swal.fire({
                icon: 'success',
                title: 'Thành công!',
                text: @Html.Raw(Json.Serialize(TempData["success"])),
                timer: 2000,
                showConfirmButton: false
            });
        </script>
    }

    @if (TempData["error"] != null)
    {
        <script>
            Swal.fire({
                icon: 'error',
                title: 'Lỗi!',
                text: @Html.Raw(Json.Serialize(TempData["error"])),
                timer: 2500,
                showConfirmButton: false
            });
        </script>
    }
}
