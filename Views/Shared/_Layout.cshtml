            }
        }

        footer {
            background-color: #1e7e34;
            color: #fff;
            padding: 30px 0;
        }

        footer a {
            color: #cfe9d8;
            text-decoration: none;
        }

        footer a:hover {
            color: #fff;
        }

        .carousel-inner img {
            width: 100%;
            height: auto;
            border-radius: 0;
            border: none;
        }

        .card {
            transition: transform 0.3s ease;
            border-radius: 10px;
        }

        .card:hover {
            transform: translateY(-5px);
            box-shadow: 0 6px 16px rgba(0, 0, 0, 0.15);
        }

        .card-img-top {
            height: 200px;
            object-fit: contain;
            background-color: #fff;
            padding: 10px;
        }

        .card-footer a:hover {
            color: #28a745;
            text-decoration: underline;
        }

        .btn-success {
            background-color: #28a745;
            border-color: #28a745;
        }

        .btn-success:hover {
            background-color: #218838;
            border-color: #1e7e34;
        }

        @@media (max-width: 768px) {
            .card-img-top {
                height: 160px;
            }

            .card-title {
                font-size: 1rem;
            }

            .card-text {
                font-size: 0.9rem;
            }
        }

        df-messenger {
            --df-messenger-bot-message: #f1f1f1;
            --df-messenger-user-message: #28a745;
            --df-messenger-button-titlebar-color: #28a745;
            --df-messenger-button-titlebar-font-color: white;
            --df-messenger-chat-background-color: white;
        }
    </style>
</head>
