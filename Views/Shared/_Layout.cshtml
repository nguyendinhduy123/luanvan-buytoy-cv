    <script src="~/js/jquery.prettyPhoto.js"></script>
    <script src="~/js/main.js"></script>
    <script src="https://code.jquery.com/ui/1.13.2/jquery-ui.min.js"></script>
    <script src="https://www.gstatic.com/dialogflow-console/fast/messenger/bootstrap.js?v=1"></script>
    <script>
                $(function () {
            $("#searchTerm").autocomplete({
                source: function (request, response) {
                    $.ajax({
                        url: "/Product/SearchSuggest",
                        data: { term: request.term },
                        success: function (data) {
                            response(data);
                        }
                    });
                },
                minLength: 2,
                select: function (event, ui) {
                    $("#searchTerm").val(ui.item.value);
                    $("#searchForm").submit();
                }
            }).autocomplete("instance")._renderItem = function (ul, item) {
                return $("<li>")
                    .append(`
                        <div class="d-flex align-items-center py-2 px-2" style="border-bottom: 1px solid #eee;">
                            <img src="${item.image}" alt="${item.label}" class="me-2 rounded" style="width: 50px; height: 50px; object-fit: contain;" />
                            <div>
                                <div class="fw-bold">${item.label}</div>
                                <div class="text-success">${item.price.toLocaleString()} ₫</div>
                            </div>
                        </div>
                    `)
                    .appendTo(ul);
            };
        });

    
</script>
    @await RenderSectionAsync("Scripts", required: false)
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    $(document).ready(function () {
        $('#logoutForm').on('submit', function (e) {
            e.preventDefault(); // chặn submit mặc định

            Swal.fire({
                title: 'Bạn chắc chắn muốn đăng xuất?',
                text: "Hành động này sẽ kết thúc phiên làm việc.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#28a745',
                cancelButtonColor: '#d33',
                confirmButtonText: 'Đăng xuất',
                cancelButtonText: 'Hủy'
            }).then((result) => {
                if (result.isConfirmed) {
                    this.submit(); // tiếp tục submit form
                }
            });
        });
    });
</script>
 


    <script>
        document.addEventListener("DOMContentLoaded", function () {
            @if (TempData["success"] != null)
            {
                    <text>
                        Swal.fire({
                            icon: 'success',
                            title: 'Thành công!',
                              text: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(TempData["success"]))

                            showConfirmButton: false,
                            timer: 2000
                        });
                    </text>
            }

            @if (TempData["warning"] != null)
            {
                    <text>
                        Swal.fire({
                            icon: 'warning',
                            title: 'Cảnh báo!',
                               @Html.Raw(System.Text.Json.JsonSerializer.Serialize(TempData["warning"]))
                            confirmButtonText: 'OK'
                        });
                    </text>
            }

            @if (TempData["error"] != null)
            {
                    <text>
                        Swal.fire({
                            icon: 'error',
                            title: 'Lỗi!',
                                @Html.Raw(System.Text.Json.JsonSerializer.Serialize(TempData["error"]))
                            confirmButtonText: 'Đóng'
                        });
                    </text>
            }
        });
    </script>


