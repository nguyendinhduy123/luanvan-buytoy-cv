            color: #fff !important;
            font-weight: 500;
            padding: 10px 20px;
            white-space: nowrap;
        }

        .navbar-nav .nav-link:hover,
        .navbar-nav .nav-link.active {
            color: #ffc107 !important;
            background-color: rgba(255, 255, 255, 0.1);
            border-radius: 6px;
        }

        .dropdown-menu {
            border-radius: 10px;
            box-shadow: 0 2px 6px rgba(0, 0, 0, 0.15);
        }

        .nav-link i {
            margin-right: 6px;
        }

        .navbar .form-control {
            min-width: 240px;
            border-radius: 20px;
            padding-left: 15px;
        }

        .navbar .btn-light {
            border-radius: 20px;
        }

        .d-flex .nav-link {
            margin-left: 15px;
        }

        .navbar-nav {
            flex-wrap: nowrap;
            gap: 10px;
        }

        @@media (max-width: 991.98px) {
            .navbar-nav {
