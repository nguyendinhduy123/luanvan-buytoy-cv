@model IEnumerable<CategoryModel>

@foreach (var item in Model)
{
    <a asp-action="Index"
       asp-controller="Category"
       asp-route-Slug="@item.Slug"
       class="list-group-item list-group-item-action d-flex align-items-center gap-3 py-2">

        <img src="~/media/categories/@item.Image" asp-append-version="true"
             alt="@item.Name"
             style="width: 50px; height: 50px; object-fit: contain; border-radius: 8px;" />

        <span>@item.Name</span>
    </a>
}
