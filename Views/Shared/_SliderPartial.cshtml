@{
    var sliders = ViewBag.Sliders as List<buytoy.Models.SliderModel>;
    int index = 0;
}
<style>
    #slider {
        margin-top: 20px;
    }

    .carousel-inner {
        height: 700px;
        overflow: hidden;
    }

    .carousel-item {
        height: 100%;
    }

        .carousel-item img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

    .carousel-indicators button {
        width: 12px;
        height: 12px;
        border-radius: 50%;
        background-color: #ffffff;
        opacity: 0.7;
    }

    .carousel-indicators .active {
        background-color: #ff3c3c;
        opacity: 1;
    }

    .carousel-control-prev-icon,
    .carousel-control-next-icon {
        filter: invert(100%);
    }
</style>

<section id="slider">
    <div class="w-100">
        @if (sliders != null && sliders.Any())
        {
            <div id="slider-carousel" class="carousel slide carousel-fade" data-bs-ride="carousel">
                <!-- Indicators -->
                <div class="carousel-indicators">
                    @for (int i = 0; i < sliders.Count; i++)
                    {
                        <button type="button"
                                data-bs-target="#slider-carousel"
                                data-bs-slide-to="@i"
                                class="@(i == 0 ? "active" : "")"
                                aria-current="@(i == 0 ? "true" : "false")"
                                aria-label="Slide @(i + 1)">
                        </button>
                    }
                </div>

                <!-- Slides -->
                <div class="carousel-inner">
                    @foreach (var slider in sliders)
                    {
                        <div class="carousel-item @(index == 0 ? "active" : "")">
                            <img src="@Url.Content("~/media/sliders/" + slider.Image)" alt="@slider.Name" />
                        </div>
                        index++;
                    }
                </div>

                <!-- Controls -->
                <button class="carousel-control-prev" type="button" data-bs-target="#slider-carousel" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                    <span class="visually-hidden">Trước</span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#slider-carousel" data-bs-slide="next">
                    <span class="carousel-control-next-icon" aria-hidden="true"></span>
                    <span class="visually-hidden">Sau</span>
                </button>
            </div>
        }
        else
        {
            <p class="text-muted text-center">Không có slider nào để hiển thị.</p>
        }
    </div>
</section>



<!-- Scripts (nếu chưa có trong layout) -->
@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
}
