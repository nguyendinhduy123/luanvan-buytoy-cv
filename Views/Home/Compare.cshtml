@model IEnumerable<dynamic>
@{
    ViewData["Title"] = "Danh sách so sánh";
    var stt = 1;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
</head>
<body>
    <div class="container py-4">
        <h2 class="text-primary mb-4"><i class="fas fa-balance-scale me-2"></i>Danh sách sản phẩm so sánh</h2>

        @if (!Model.Any())
        {
            <div class="alert alert-info">Chưa có sản phẩm nào trong danh sách so sánh.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-bordered table-striped align-middle text-center bg-white">
                    <thead class="table-success">
                        <tr>
                            <th>#</th>
                            <th>Tên sản phẩm</th>
                            <th>Mô tả</th>
                            <th>Giá</th>
                            <th>Hình ảnh</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@stt</td>
                                @{
                                    stt++;
                                }
                                <td>@item.Product.Name</td>
                                <td>@Html.Raw(item.Product.Description)</td>
                                <td class="text-danger fw-bold">@item.Product.Price.ToString("N0") ₫</td>
                                <td>
                                    <img src="~/media/products/@item.Product.Image" alt="@item.Product.Name" style="max-height: 100px;" class="img-thumbnail" />
                                </td>
                                <td>
                                    <a href="#" class="btn btn-sm btn-danger delete-compare"
                                       data-url="@Url.Action("DeleteCompare", "Home", new { Id = item.Compares.Id })">
                                        Xóa
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>

    <script>
        $(document).ready(function () {
            // Xác nhận xóa sản phẩm so sánh
            $('.delete-compare').click(function (e) {
                e.preventDefault();
                var url = $(this).data('url');

                Swal.fire({
                    title: 'Bạn có chắc muốn xóa?',
                    text: "Sản phẩm sẽ bị xóa khỏi danh sách so sánh.",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#d33',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Xóa',
                    cancelButtonText: 'Hủy'
                }).then((result) => {
                    if (result.isConfirmed) {
                        window.location.href = url;
                    }
                });
            });

            // Đồng bộ localStorage -> server
            const compare = JSON.parse(localStorage.getItem("compare") || "[]");
            if (compare.length > 0) {
                $.ajax({
                    type: "POST",
                    url: "/Home/SyncCompare",
                    contentType: "application/json",
                    data: JSON.stringify(compare),
                    success: function () {
                        console.log("✅ Đã đồng bộ so sánh");
                        localStorage.removeItem("compare"); // Xóa sau khi sync
                        location.reload();
                    },
                    error: function () {
                        console.error("❌ Lỗi khi đồng bộ danh sách so sánh");
                    }
                });
            }
        });
    </script>
</body>
</html>
