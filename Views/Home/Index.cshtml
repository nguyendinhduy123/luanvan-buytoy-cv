@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function () {

            $('.add-to-cart').click(function (e) {
                e.preventDefault();
                var productId = $(this).data("product_id");

                $.post("@Url.Action("Add", "Cart")", { Id: productId })
                    .done(function () {
                        Swal.fire({
                            icon: 'success',
                            title: 'Đã thêm vào giỏ hàng!',
                            text: 'Sản phẩm đã được thêm thành công.',
                            timer: 2000,
                            showConfirmButton: false
                        });
                    })
                    .fail(function () {
                        Swal.fire({
                            icon: 'error',
                            title: 'Lỗi!',
                            text: 'Không thể thêm sản phẩm. Vui lòng thử lại.',
                            timer: 2000,
                            showConfirmButton: false
                        });
                    });
            });

            $('.add-to-wishlist').click(function (e) {
                e.preventDefault();
                const id = $(this).data("product_id");
                const name = $(this).data("name");
                let wishlist = JSON.parse(localStorage.getItem("wishlist") || "[]");

                if (!wishlist.includes(id)) {
                    wishlist.push(id);
                    localStorage.setItem("wishlist", JSON.stringify(wishlist));
                    Swal.fire({
                        icon: 'success',
                        title: 'Đã thêm yêu thích!',
                        text: `${name} đã được thêm vào danh sách yêu thích.`,
                        timer: 2000,
                        showConfirmButton: false
                    });
                } else {
                    Swal.fire({
                        icon: 'info',
                        title: 'Đã tồn tại!',
                        text: 'Sản phẩm đã có trong danh sách yêu thích.',
                        timer: 2000,
                        showConfirmButton: false
                    });
                }
            });

            $('.add-to-compare').click(function (e) {
                e.preventDefault();
                const id = $(this).data("product_id");
                const name = $(this).data("name");
                let compare = JSON.parse(localStorage.getItem("compare") || "[]");

                if (!compare.includes(id)) {
                    if (compare.length >= 3) {
                        Swal.fire({
                            icon: 'warning',
                            title: 'Giới hạn 3 sản phẩm!',
                            text: 'Chỉ có thể so sánh tối đa 3 sản phẩm.',
                            timer: 2000,
                            showConfirmButton: false
                        });
                        return;
                    }
                    compare.push(id);
                    localStorage.setItem("compare", JSON.stringify(compare));
                    Swal.fire({
                        icon: 'success',
                        title: 'Đã thêm so sánh!',
                        text: `${name} đã được thêm vào danh sách so sánh.`,
                        timer: 2000,
                        showConfirmButton: false
                    });
                } else {
                    Swal.fire({
                        icon: 'info',
                        title: 'Đã tồn tại!',
                        text: 'Sản phẩm đã có trong danh sách so sánh.',
                        timer: 2000,
                        showConfirmButton: false
                    });
                }
            });
        });
    </script>
    <script src="https://code.jquery.com/ui/1.13.2/jquery-ui.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        $(document).ready(function () {
            // Khởi tạo slider lọc giá
            $("#slider-range").slider({
            range: true,
            min: 0,
            max: 100000000, // Giá tối đa tự đặt
            step: 50000,
            values: [100000, 800000], // Giá trị mặc định khi vào trang
            slide: function (event, ui) {
                $("#amount").val("đ" + ui.values[0].toLocaleString('vi-VN') + " - đ" + ui.values[1].toLocaleString('vi-VN'));
            }
        });
            $("#amount").val(
                "đ" + $("#slider-range").slider("values", 0).toLocaleString('vi-VN') +
                " - đ" + $("#slider-range").slider("values", 1).toLocaleString('vi-VN')
            );

            // Lọc theo giá
            $('.btn-locgia').on('click', function () {
                var url = $(this).data("current_url");
                if (url) {
                    window.location = url + "?startprice=" + $("#slider-range").slider("values", 0)
                        + "&endprice=" + $("#slider-range").slider("values", 1);
                }
            });

            // Sắp xếp
            $('#sort_by').on('change', function () {
                var url = $(this).val();
                if (url) {
                    window.location = url;
                }
            });
        });
    </script>
}