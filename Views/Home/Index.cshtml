@model IEnumerable<ProductModel>
<style>
    .product-image-wrapper {
        border: 1px solid #e0e0e0;
        border-radius: 12px;
        padding: 15px;
        margin-bottom: 30px;
        background: #fff;
        height: 100%;
        transition: all 0.3s ease;
    }

        .product-image-wrapper:hover {
            box-shadow: 0 8px 30px rgba(0, 0, 0, 0.1);
            transform: translateY(-5px);
        }

    .productinfo img {
        max-height: 220px;
        object-fit: contain;
        margin-bottom: 15px;
        transition: transform 0.3s ease;
    }

    .productinfo:hover img {
        transform: scale(1.05);
    }

    .productinfo h2 {
        font-size: 18px;
        color: #28a745;
        margin-bottom: 10px;
        font-weight: 600;
    }

    .productinfo p {
        font-size: 14px;
        color: #444;
        margin: 4px 0;
    }

    .add-to-cart {
        background-color: #fe980f;
        color: white;
        font-weight: 500;
        border: none;
        transition: background-color 0.2s ease;
    }

        .add-to-cart:hover {
            background-color: #ec7c05;
        }

    .choose {
        border-top: 1px solid #eee;
        padding-top: 10px;
    }

    .action-links {
        display: flex;
        justify-content: space-around;
        padding: 5px 0;
    }

        .action-links a {
            display: flex;
            align-items: center;
            font-size: 14px;
            color: #444;
            text-decoration: none;
            transition: color 0.3s ease;
        }

            .action-links a i {
                margin-right: 6px;
                color: #fe980f;
                font-size: 16px;
            }

            .action-links a:hover {
                color: #28a745;
            }
</style>



