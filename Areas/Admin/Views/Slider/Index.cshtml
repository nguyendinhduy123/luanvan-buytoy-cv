@model IEnumerable<buytoy.Models.SliderModel>

@{
    ViewData["Title"] = "Danh sách Slider";
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
</head>
<body>

    <div class="container-fluid">
        <div class="row">
            <div class="col-md-12 p-4">
                <h3 class="mb-4">Danh sách Slider</h3>

                <a class="btn btn-primary mb-3" asp-action="Create" asp-controller="Slider">Thêm Slider</a>

                <div class="table-responsive">
                    <table class="table table-bordered table-hover" id="myTable">
                        <thead class="table-dark">
                            <tr>
                                <th>ID</th>
                                <th>Tên Slider</th>
                                <th>Mô tả</th>
                                <th>Hình ảnh</th>
                                <th>Trạng thái</th>
                                <th>Hành động</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.Id</td>
                                    <td>@item.Name</td>
                                    <td>@Html.Raw(item.Description)</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(item.Image))
                                        {
                                            <img src="~/media/sliders/@item.Image" alt="Slider" style="max-height: 80px;" />
                                        }
                                    </td>
                                    <td>
                                        @if (item.Status == 1)
                                        {
                                            <span class="text-success">Hiển thị</span>
                                        }
                                        else
                                        {
                                            <span class="text-danger">Ẩn</span>
                                        }
                                    </td>
                                    <td>
                                        <a class="btn btn-warning btn-sm" asp-action="Edit" asp-controller="Slider" asp-route-id="@item.Id">Sửa</a>
                                        <a class="btn btn-danger btn-sm confirmDeletion" asp-action="Delete" asp-controller="Slider" asp-route-id="@item.Id">Xóa</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

            </div>
        </div>
    </div>

</body>
</html>
