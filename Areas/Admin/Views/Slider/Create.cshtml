@model SliderModel

@{
    ViewData["Title"] = "Thêm Slider mới";
}

<h3 class="mb-4">Thêm Slider mới</h3>

<div class="col-md-9">
    <form asp-action="Create" enctype="multipart/form-data">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <!-- Tên slider -->
        <div class="form-group">
            <label>Tên slider</label>
            <input asp-for="Name" class="form-control" placeholder="Nhập tên slider" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <!-- Mô tả (sử dụng CKEditor) -->
        <div class="form-group">
            <label>Mô tả</label>
            <textarea asp-for="Description" class="form-control" placeholder="Nhập mô tả chi tiết..."></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <!-- Ảnh slider -->
        <div class="form-group">
            <label>Ảnh slider</label>
            <input asp-for="ImageUpload" class="form-control" accept=".jpg,.jpeg,.png" />
            <span asp-validation-for="ImageUpload" class="text-danger"></span>
            <img id="imgpreview" class="pt-2" style="max-height: 200px;" />
        </div>

        <!-- Trạng thái -->
        <div class="form-group">
            <label>Trạng thái</label>
            <select asp-for="Status" class="form-control">
                <option value="1">Hiển thị</option>
                <option value="0">Ẩn</option>
            </select>
            <span asp-validation-for="Status" class="text-danger"></span>
        </div>

        <!-- Nút Submit -->
        <div class="form-group mt-3">
            <button class="btn btn-success">Thêm Slider</button>
        </div>
    </form>

    <a asp-action="Index">← Quay lại danh sách slider</a>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")

    <script src="https://cdn.ckeditor.com/4.22.1/standard/ckeditor.js"></script>
    <script>
        // Xem trước ảnh slider
        $("#ImageUpload").change(function () {
            const reader = new FileReader();
            reader.onload = function (e) {
                $('#imgpreview').attr('src', e.target.result);
            };
            reader.readAsDataURL(this.files[0]);
        });

        // Gắn CKEditor vào mô tả
        CKEDITOR.replace('Description', {
            language: 'vi',
            contentsLanguage: 'vi',
            font_names: 'Arial;Times New Roman;Verdana;Tahoma',
            defaultLanguage: 'vi',
            entities_latin: false,
            entities_greek: false
        });
    </script>
}
