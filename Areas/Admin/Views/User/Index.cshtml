@{
    ViewData["Title"] = "Danh sách người dùng";
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
</head>
<body>

    <div class="main-panel" style="padding: 24px;">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h3 class="mb-0">Danh sách người dùng</h3>
            <a class="btn btn-primary" asp-action="Create" asp-controller="User">Thêm người dùng</a>
        </div>

        <div class="table-responsive">
            <table class="table table-bordered table-hover align-middle text-center" id="myTable">
                <thead class="table-dark">
                    <tr>
                        <th style="min-width: 150px;">ID</th>
                        <th style="min-width: 130px;">Tên đăng nhập</th>
                        <th style="min-width: 200px;">Email</th>
                        <th style="min-width: 250px;">Mật khẩu (Hash)</th>
                        <th style="min-width: 130px;">Số điện thoại</th>
                        <th style="min-width: 100px;">Quyền</th>
                        <th style="min-width: 150px;">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var usersWithRoles in Model)
                    {
                        <tr>
                            <td>@usersWithRoles.User.Id</td>
                            <td>@usersWithRoles.User.UserName</td>
                            <td>@usersWithRoles.User.Email</td>
                            <td class="text-truncate" style="max-width: 250px;">@usersWithRoles.User.PasswordHash</td>
                            <td>@usersWithRoles.User.PhoneNumber</td>
                            <td>@usersWithRoles.RoleName</td>
                            <td>
                                @if (usersWithRoles.User.Id != (string)ViewBag.loggedInUserId && usersWithRoles.RoleName != "Admin")
                                {
                                    <div class="d-flex justify-content-center gap-2">
                                        <a class="btn btn-warning btn-sm" asp-action="Edit" asp-controller="User" asp-route-id="@usersWithRoles.User.Id">Sửa</a>
                                        <a class="btn btn-danger btn-sm" asp-action="Delete" asp-controller="User" asp-route-id="@usersWithRoles.User.Id"
                                           onclick="return confirm('Bạn có chắc chắn muốn xóa người dùng này không?')">Xóa</a>
                                    </div>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</body>
</html>
