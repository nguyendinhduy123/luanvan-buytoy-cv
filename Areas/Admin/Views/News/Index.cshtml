@model IEnumerable<buytoy.Models.NewsModel>
@{
    ViewData["Title"] = "Quản lý tin tức";
}

<h2 class="mb-4">Danh sách tin tức mới</h2>

@if (TempData["success"] != null)
{
    <div class="alert alert-success">@TempData["success"]</div>
}

<div class="mb-3">
    <a asp-action="Create" class="btn btn-success">+ Thêm tin tức</a>
    
</div>

<table class="table table-hover table-bordered">
    <thead>
        <tr>
            <th>Tiêu đề</th>
            <th>Ngày đăng</th>
            <th>Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Title</td>
                <td>@item.CreatedAt.ToString("dd/MM/yyyy")</td>
                <td>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm"
                       onclick="return confirm('Bạn có chắc chắn muốn xoá tin này?');">Xoá</a>
                </td>
            </tr>
        }
    </tbody>
</table>
