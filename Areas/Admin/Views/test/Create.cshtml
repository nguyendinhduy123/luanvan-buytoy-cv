@model buytoy.Models.test
@{
    ViewData["Title"] = "Thêm test";
}

<h3>Thêm mới test</h3>

<div class="col-md-9">
    <form asp-action="Create" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="form-group">
            <label asp-for="Name"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Create"></label>
            <input asp-for="Create" class="form-control" />
            <span asp-validation-for="Create" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Update"></label>
            <input asp-for="Update" class="form-control" />
            <span asp-validation-for="Update" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Delete"></label>
            <input asp-for="Delete" class="form-control" />
            <span asp-validation-for="Delete" class="text-danger"></span>
        </div>

        <div class="form-group">
            <button class="btn btn-primary">Tạo</button>
        </div>
    </form>

    <a asp-action="Index">Về danh sách</a>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
