@model buytoy.Models.test

@{
    ViewData["Title"] = "Chỉnh sửa test";
}

<h2 class="text-primary">Chỉnh sửa test</h2>

<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />

    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Create" class="form-label"></label>
        <input asp-for="Create" class="form-control" />
        <span asp-validation-for="Create" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Update" class="form-label"></label>
        <input asp-for="Update" class="form-control" />
        <span asp-validation-for="Update" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Delete" class="form-label"></label>
        <input asp-for="Delete" class="form-control" />
        <span asp-validation-for="Delete" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-success">Lưu thay đổi</button>
    <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
