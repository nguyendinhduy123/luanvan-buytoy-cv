@model IEnumerable<BrandModel>

@{
    ViewData["Title"] = "Danh sách thương hiệu";
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
</head>
<body>

    <div class="container-fluid">
        <div class="row">
            <!-- Nếu bạn có sidebar, phần này sẽ là col-md-2 -->
            @* <div class="col-md-2 bg-dark text-white min-vh-100">
                Sidebar nếu có
            </div> *@

            <div class="col-md-12 p-4">
                <h3 class="mb-4">Danh sách thương hiệu</h3>

                <a class="btn btn-primary mb-3" asp-action="Create" asp-controller="Brand">Thêm thương hiệu</a>

                <div class="table-responsive">
                    <table class="table table-bordered table-hover" id="myTable">
                        <thead class="table-dark">
                            <tr>
                                <th>ID</th>
                                <th>Tên thương hiệu</th>
                                <th>Hình ảnh</th>
                                <th>Mô tả</th>
                                <th>Slug</th>
                                <th>Trạng thái</th>
                                <th>Hành động</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.Id</td>
                                    <td>@item.Name</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(item.Image))
                                        {
                                            <img src="~/media/brands/@item.Image" style="height: 40px; width: auto;" />
                                        }
                                    </td>
                                    <td>@Html.Raw(item.Description)</td>
                                    <td>@item.Slug</td>
                                    <td>
                                        @if (item.Status == 1)
                                        {
                                            <span class="text-success">Hiển thị</span>
                                        }
                                        else
                                        {
                                            <span class="text-danger">Ẩn</span>
                                        }
                                    </td>
                                    <td>
                                        <a class="btn btn-warning btn-sm" asp-action="Edit" asp-controller="Brand" asp-route-Id="@item.Id">Sửa</a>
                                        <a class="btn btn-danger btn-sm confirmDeletion" asp-action="Delete" asp-controller="Brand" asp-route-Id="@item.Id">Xóa</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @* Phân trang (nếu cần sau này) *@
                @* <partial name="_paging" model="@pager" /> *@
            </div>
        </div>
    </div>

</body>
</html>
