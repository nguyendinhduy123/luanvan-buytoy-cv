@model ProductModel
@{
    ViewData["Title"] = "Chỉnh sửa sản phẩm";
}

<h3 class="text-success mb-4">Chỉnh sửa sản phẩm</h3>

<div class="col-md-9">
    <form asp-action="Edit" enctype="multipart/form-data">
        <input type="hidden" asp-for="Id" />

        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="form-group mb-3">
            <label>Tên sản phẩm</label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label>Mô tả ngắn</label>
            <textarea asp-for="ShortDescription" class="form-control" rows="2"></textarea>
            <span asp-validation-for="ShortDescription" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label>Tuổi tối thiểu</label>
            <input asp-for="MinAge" class="form-control" />
            <span asp-validation-for="MinAge" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label>Tuổi tối đa</label>
            <input asp-for="MaxAge" class="form-control" />
            <span asp-validation-for="MaxAge" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label>Giá bán (VNĐ)</label>
            <input name="Price" class="form-control" type="number" step="1000" min="0" value="@Model.Price.ToString("0")" />
            <span asp-validation-for="Price" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label>Mô tả chi tiết</label>
            <textarea asp-for="Description" class="form-control"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label>Danh mục</label>
            <select asp-for="CategoryId" class="form-control" asp-items="ViewBag.Categories">
                <option>-- Chọn danh mục --</option>
            </select>
            <span asp-validation-for="CategoryId" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label>Thương hiệu</label>
            <select asp-for="BrandId" class="form-control" asp-items="ViewBag.Brands">
                <option>-- Chọn thương hiệu --</option>
            </select>
            <span asp-validation-for="BrandId" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label>Hình ảnh</label>
            <input asp-for="ImageUpload" class="form-control" accept=".jpg,.jpeg,.png" />
            <span asp-validation-for="ImageUpload" class="text-danger"></span>
            <div class="pt-2">
                <img src="~/media/products/@Model.Image" asp-append-version="true" width="120" />
                <img id="imgpreview" class="pt-2" />
            </div>
        </div>

        <div class="form-group mb-4">
            <button class="btn btn-success">Lưu thay đổi</button>
        </div>
    </form>

    <a asp-action="Index" class="btn btn-link">← Quay lại danh sách sản phẩm</a>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.ckeditor.com/4.22.1/standard/ckeditor.js"></script>
    <script>
        CKEDITOR.replace('Description');
    </script>
}
