@using Microsoft.AspNetCore.Identity
@model IEnumerable<IdentityRole>

@{
    ViewData["Title"] = "Danh sách quyền";
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
</head>
<body>

    <div class="main-panel" style="padding: 24px;">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h3 class="mb-0">Danh sách quyền (Role)</h3>
            <a class="btn btn-primary" asp-action="Create" asp-controller="Role">Thêm quyền</a>
        </div>

        <div class="table-responsive">
            <table class="table table-bordered table-hover text-center align-middle" id="myTable">
                <thead class="table-dark">
                    <tr>
                        <th style="min-width: 150px;">ID</th>
                        <th style="min-width: 180px;">Tên quyền</th>
                        <th style="min-width: 180px;">Chuẩn hóa</th>
                        <th style="min-width: 150px;">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td>@item.Name</td>
                            <td>@item.NormalizedName</td>
                            <td>
                                <div class="d-flex justify-content-center gap-2">
                                    <a class="btn btn-warning btn-sm" asp-action="Edit" asp-controller="Role" asp-route-id="@item.Id">Sửa</a>
                                    <a class="btn btn-danger btn-sm" asp-action="Delete" asp-controller="Role" asp-route-id="@item.Id"
                                       onclick="return confirm('Bạn có chắc chắn muốn xóa quyền này không?')">Xóa</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</body>
</html>
