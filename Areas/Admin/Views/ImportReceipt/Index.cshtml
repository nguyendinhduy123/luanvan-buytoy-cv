@model IEnumerable<buytoy.Models.ImportReceiptModel>
@{
    ViewData["Title"] = "Danh sách phiếu nhập";
}
<h2>Danh sách phiếu nhập hàng</h2>

<a asp-action="Create" class="btn btn-success mb-3"><i class="fas fa-plus"></i> Tạo phiếu nhập</a>

<table id="myTable" class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>#</th>
            <th>Nhà cung cấp</th>
            <th>Ngày nhập</th>
            <th>Tổng tiền</th>
            <th>Ghi chú</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var r in Model)
        {
            <tr>
                <td>@r.Id</td>
                <td>@r.Supplier?.Name</td>
                <td>@r.ImportDate.ToString("dd/MM/yyyy")</td>
                <td>@r.TotalAmount.ToString("N0") ₫</td>
                <td>@r.Note</td>
            </tr>
        }
    </tbody>
</table>
